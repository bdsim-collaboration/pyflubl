d1: drift, l=1*m;
q1: quadrupole, l=0.25, k1=-0.2;
d2: drift, l=1*m;
c: rcol, l=0.01*m, xsize=0, ysize=0, material="G4_Fe";
d3: drift, l=1*m;
b1: sbend, l=2/10*m, angle=pi/4/10;
d4: drift, l=1*m;

l: line=(d1,q1,d2,c,d3,b1,b1,b1,b1,b1,b1,b1,b1,b1,b1,d4);

use, period=l;

beam, particle="e-", energy=1*GeV;

option, magnetGeometryType="none",
        physicsList="em em_extra qgsp_bert",
	beampipeThickness=5e-3,
	beampipeMaterial="G4_Fe",
	defaultRangeCut=15*cm, 
        prodCutPhotons=5*cm,
        prodCutElectrons=5*cm,
        prodCutPositrons=5*cm;